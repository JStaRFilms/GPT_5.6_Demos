{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://model-observatory.local/showcase-meta.schema.json",
  "title": "Model Observatory build-record metadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["session", "model"],
  "properties": {
    "$schema": { "type": "string" },
    "title": { "type": "string", "minLength": 1 },
    "session": { "type": "string", "pattern": "^pi-session-[A-Za-z0-9._-]+\\.html$" },
    "model": { "enum": ["sol", "terra", "luna"] }
  }
}
