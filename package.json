{
  "name": "model-showcase",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "generate": "tsx scripts/generate-showcase.ts",
    "dev": "pnpm generate && next dev",
    "build": "pnpm generate && pnpm exec tsx scripts/validate-showcase.ts && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "pnpm generate && tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "validate": "pnpm generate && tsx scripts/validate-showcase.ts",
    "verify": "python scripts/vibe-verify.py"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.16"
    }
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "24.7.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.1",
    "globals": "17.7.0",
    "postcss": "8.5.16",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.1"
  }
}
